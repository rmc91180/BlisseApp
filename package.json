{
  "name": "blisseapp",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix",
    "typecheck": "tsc --noEmit",
    "check:i18n": "node scripts/check-i18n-consistency.mjs",
    "check:content": "node scripts/check-content-integrity.mjs",
    "check:release": "npm run lint && npm run typecheck && npm run check:i18n && npm run check:content && npx expo-doctor && npm audit --omit=dev",
    "ui:smoke": "npx expo export --platform all --output-dir dist-check",
    "ui:e2e:ios": "maestro test .maestro/flows/ios-beta-smoke.yaml",
    "ui:e2e:android": "maestro test .maestro/flows/android-beta-smoke.yaml"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.9.0",
    "@react-navigation/native": "^7.1.26",
    "@react-navigation/native-stack": "^7.9.0",
    "@react-navigation/stack": "^7.6.16",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-application": "~7.0.8",
    "expo-av": "~16.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-local-authentication": "~17.0.8",
    "expo-localization": "~17.0.8",
    "expo-network": "~8.0.8",
    "expo-notifications": "^0.32.16",
    "expo-secure-store": "^15.0.8",
    "expo-status-bar": "~3.0.9",
    "firebase": "^12.7.0",
    "posthog-react-native": "^4.17.2",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-purchases": "^9.10.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~19.1.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "@isaacs/brace-expansion": "5.0.1"
  },
  "private": true
}
