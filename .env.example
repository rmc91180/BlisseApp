## Public (safe to embed in the app bundle)
# PostHog project key + host (analytics)
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Firebase Configuration (these are public keys, safe for client-side use)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=
EXPO_PUBLIC_FIREBASE_FUNCTIONS_REGION=us-central1
# Optional override if you use a custom function domain
# EXPO_PUBLIC_FIREBASE_FUNCTIONS_BASE_URL=https://us-central1-your-project.cloudfunctions.net

# Formspree form endpoint (contact/ideas form)
EXPO_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/xvzgeaqp

# RevenueCat (billing/subscription gate)
# Use public SDK keys from RevenueCat project settings per platform
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
# Entitlement identifier configured in RevenueCat (example: pro, premium)
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=pro
# Optional: force paywall requirement in non-production builds
# EXPO_PUBLIC_REVENUECAT_REQUIRED=true

# Reviewer / test bypass accounts (comma-separated)
# Example:
# EXPO_PUBLIC_REVIEW_BYPASS_EMAILS=review@blisse.online,qa@yourdomain.com
# Legacy single value is still supported:
# EXPO_PUBLIC_REVIEW_BYPASS_EMAIL=review@blisse.online
